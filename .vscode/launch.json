{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Questboard (Example App)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/packages/titan_example"
    },
    {
      "name": "Questboard (Web)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/packages/titan_example",
      "args": [
        "--web-port",
        "8080"
      ],
      "deviceId": "chrome"
    },
    {
      "name": "Questboard (Web + MCP Server)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/packages/titan_example",
      "args": [
        "--web-port",
        "8080"
      ],
      "deviceId": "chrome",
      "preLaunchTask": "Start MCP Server"
    },
    {
      "name": "MCP Server (Auto Transport)",
      "type": "dart",
      "request": "launch",
      "program": "bin/blueprint_mcp_server.dart",
      "cwd": "${workspaceFolder}/packages/titan_colossus",
      "args": [
        "--transport",
        "auto",
        "--port",
        "3001",
        "--host",
        "127.0.0.1"
      ]
    },
    {
      "name": "Questboard (Profile Mode)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/packages/titan_example",
      "flutterMode": "profile"
    },
    {
      "name": "Questboard (Release Mode)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/packages/titan_example",
      "flutterMode": "release"
    },
    {
      "name": "Run All Titan Core Tests",
      "type": "dart",
      "request": "launch",
      "program": "test/",
      "cwd": "${workspaceFolder}/packages/titan"
    },
    {
      "name": "Run All Bastion Tests",
      "type": "dart",
      "request": "launch",
      "program": "test/",
      "cwd": "${workspaceFolder}/packages/titan_bastion"
    },
    {
      "name": "Run All Atlas Tests",
      "type": "dart",
      "request": "launch",
      "program": "test/",
      "cwd": "${workspaceFolder}/packages/titan_atlas"
    },
    {
      "name": "Run Example App Tests",
      "type": "dart",
      "request": "launch",
      "program": "test/",
      "cwd": "${workspaceFolder}/packages/titan_example"
    }
  ],
  "compounds": [
    {
      "name": "Run All Tests",
      "configurations": [
        "Run All Titan Core Tests",
        "Run All Bastion Tests",
        "Run All Atlas Tests",
        "Run Example App Tests"
      ]
    },
    {
      "name": "Web + MCP Server",
      "configurations": [
        "Questboard (Web)",
        "MCP Server (Auto Transport)"
      ]
    }
  ]
}
