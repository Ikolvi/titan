{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start MCP Server",
      "type": "shell",
      "command": "dart",
      "args": [
        "run",
        "bin/blueprint_mcp_server.dart",
        "--transport",
        "auto",
        "--port",
        "3001",
        "--host",
        "127.0.0.1"
      ],
      "options": {
        "cwd": "${workspaceFolder}/packages/titan_colossus"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^MCP auto-detect server",
          "endsPattern": "^MCP auto-detect server"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "close": false
      }
    }
  ]
}
